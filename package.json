{
  "name": "explainer-3d",
  "version": "1.0.0",
  "description": "3D animated explainer video framework — Remotion + React Three Fiber",
  "type": "module",
  "scripts": {
    "start": "remotion studio",
    "studio": "remotion studio",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "render": "remotion render src/index.ts",
    "render:all": "tsx src/renderer/render-all.ts",
    "render:lambda": "tsx src/renderer/render-all.ts --lambda",
    "render:ai-dev-flow": "remotion render src/index.ts AIDevFlow out/ai-dev-flow.mp4 --gl=swangle"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.5.0",
    "@react-three/postprocessing": "3.0.4",
    "@remotion/bundler": "4.0.429",
    "@remotion/cli": "4.0.429",
    "@remotion/lambda": "4.0.429",
    "@remotion/renderer": "4.0.429",
    "@remotion/three": "4.0.429",
    "postprocessing": "6.36.7",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.429",
    "three": "0.173.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config": "4.0.429",
    "@remotion/eslint-plugin": "^4.0.429",
    "@types/react": "19.0.0",
    "@types/three": "0.173.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "3.0.0",
    "eslint": "8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "4.19.0",
    "typescript": "5.7.3",
    "vitest": "3.0.0"
  }
}
